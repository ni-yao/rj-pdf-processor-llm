# Azure AI Foundry / Content Understanding
AZURE_AI_ENDPOINT=https://<your-resource-name>.services.ai.azure.com/

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=pdf-uploads

# Model deployment names (must match your Foundry deployments)
GPT_41_DEPLOYMENT=gpt-5-chat
GPT_41_MINI_DEPLOYMENT=gpt-4.1-mini

# Content Understanding analyzer ID
ANALYZER_ID=banking-annual-report

# Local paths (relative to project root)
INPUT_FOLDER=input
OUTPUT_FOLDER=output

# Processing settings
CONFIDENCE_THRESHOLD=0.60
POLL_INTERVAL_SECONDS=5
POLL_TIMEOUT_SECONDS=600
